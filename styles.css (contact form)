body {
  font-family: Arial, sans-serif;
  background-color: #f2f2f2;
}

.form-container {
  background-color: #ffffff;
  border-radius: 10px;
  padding: 30px;
  width: 400px;
  margin: 50px auto;
}

h2 {
  text-align: center;
}

label {
  display: block;
  margin: 10px 0;
  color: #333333;
}

input,
textarea {
  width: 100%;
  padding: 10px;
  margin-bottom: 15px;
  box-sizing: border-box;
}

textarea {
  height: 120px;
}

button {
  background-color: #007bff;
  font-size: 18px;
  color: white;
  padding: 10px 20px;
  border: none;
  border-radius: 5px;
  cursor: pointer;
}

button:hover {
  background-color: #0056b3;
}
