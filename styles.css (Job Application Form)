body {
  font-family: Arial, sans-serif;
  background-color: #202040;
  color: white;
}

.container {
  width: 80%;
  max-width: 600px;
  margin: 40px auto;
  background-color: #ffffff1a;
  padding: 30px;
  border-radius: 10px;
}

form {
  display: flex;
  flex-direction: column;
}

label {
  margin-top: 15px;
}

input,
select,
textarea {
  padding: 10px;
  margin-top: 5px;
  border: 2px solid gray;
  border-radius: 5px;
  font-size: 1rem;
}

/* First input styled differently */
input:first-of-type {
  border-radius: 15px;
}

/* Focus styles */
input:focus,
textarea:focus {
  outline: none;
  border-color: royalblue;
}

/* Validation styles */
input:invalid,
select:invalid,
textarea:invalid {
  border-color: red;
}

input:valid,
select:valid,
textarea:valid {
  border-color: green;
}

.radio-group {
  margin-top: 20px;
  padding: 15px;
  border: 1px solid white;
  border-radius: 8px;
}

.radio-group input[type="radio"] {
  accent-color: royalblue;
}

/* Checked radio button styling */
.radio-group input[type="radio"]:checked {
  border-color: limegreen;
  background-color: limegreen;
  box-shadow: 0 0 5px limegreen;
}

/* Change label color when selected */
.radio-group input[type="radio"]:checked + label {
  color: lightgreen;
}

button {
  margin-top: 20px;
  padding: 12px;
  border: none;
  border-radius: 6px;
  background-color: royalblue;
  color: white;
  font-size: 1.1rem;
  cursor: pointer;
}

button:hover {
  background-color: midnightblue;
}
